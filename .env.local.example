# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# Canonical site URL (JSON-LD; optional — code defaults for production)
NEXT_PUBLIC_SITE_URL=https://www.starlynncare.com

# Google Tag Manager — https://tagmanager.google.com/ → open your container →
# ID in the top bar next to the container name (format GTM-XXXXXXX). Not used by the app until GTM is installed in layout.
NEXT_PUBLIC_GTM_ID=

# Supabase — Settings → API (same project URL for all keys)
NEXT_PUBLIC_SUPABASE_URL=
# New dashboard label: "Publishable" API key (browser + server SSR reads under RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy name — still supported if your env already uses it:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Third key: Dashboard → Settings → API → Project API keys → service_role → Reveal
# Required for scrapers / admin bypass of RLS — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Postgres URI for Python ingest scripts (Dashboard → Database → Connection string → URI)
DATABASE_URL=

# Anthropic — required for scrapers/generate_content.py
# Create at https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Google Maps Platform — required for scrapers/fetch_photos.py (Street View Static API)
# Enable at https://console.cloud.google.com/ → APIs & Services → Street View Static API
# Cost: ~$0.007 per image fetch × 14 facilities ≈ $0.10 one-time
GOOGLE_MAPS_API_KEY=

# Waitlist (optional — API falls back to console log if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated emails allowed to access /admin and /api/admin/* (Clerk must match one).
# Unset or empty = no one can access admin (fail-closed). Set in Vercel for production.
ADMIN_EMAILS=

# Site-wide launch gate (set to enable password protection; remove to disable)
SITE_UNLOCK_PASSWORD=
