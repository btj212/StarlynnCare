# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# Canonical site URL (JSON-LD, optional — defaults to production domain in code)
NEXT_PUBLIC_SITE_URL=https://www.starlynncare.com

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: never expose to the browser or Client Components
SUPABASE_SERVICE_ROLE_KEY=

# Waitlist (optional — API falls back to console log if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
